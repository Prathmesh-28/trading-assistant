# ---- Groww (data + optional orders). Blank -> synthetic test feed ----
GROWW_API_KEY=
GROWW_API_SECRET=
GROWW_TOTP_SECRET=          # Groww Cloud API keys page -> "Generate TOTP"

# ---- Telegram (phone alerts). Blank -> alerts print to console ----
TELEGRAM_BOT_TOKEN=         # from @BotFather /newbot
TELEGRAM_CHAT_ID=           # from api.telegram.org/bot<TOKEN>/getUpdates

# ---- Dashboard login (web UI + API). CHANGE THESE IN PRODUCTION ----
AUTH_USERNAME=prathmesh
AUTH_PASSWORD=trade@2026

# ---- Universe + risk ----
WATCHLIST=RELIANCE,HDFCBANK,ICICIBANK,INFY,TCS,SBIN,TATAMOTORS,LT,AXISBANK,BHARTIARTL
CAPITAL=100000
RISK_PER_TRADE_PCT=0.5
MAX_POSITION_VALUE=50000
ALLOW_SHORTS=false

# ---- Intraday strategy (paper defaults: 5-min opening range, 2R target) ----
POLL_SECONDS=20
ORB_MINUTES=5
BAR_MINUTES=5
RISK_REWARD=2.0

# ---- Journal ----
JOURNAL_PATH=journal.db
# DATABASE_URL=postgresql://...   # optional Postgres for the dashboard

# ---- Web dashboard (server.py) ----
# Comma-separated origins allowed to call the API / open the websocket.
# Set this in production to your deployed Vercel URL, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# ---- Execute mode only (orchestrator.py) ----
LIVE=false

# ---- Reserved, not yet wired to any feature ----
# Requested but no target feature specified — tell Claude which part of the
# app should use OpenAI (e.g. an alternate analyst) and this gets wired in.
OPENAI_API_KEY=
